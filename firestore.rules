rules_version = '2';

// Regras de segurança do Firestore do Munny (publicadas no console em 2026-07).
// Onde ver/editar: console.firebase.google.com > projeto munny-d72cd >
// Firestore > aba "Regras".
//
// users/{uid}/**: os dados do app; cada pessoa lê e escreve só o próprio doc e
// subcoleções. Mantém a forma recursiva {document=**} que já estava em produção.
// subscriptions/{uid}: quem tem assinatura ativa. A pessoa LÊ o próprio doc (é
// assim que o app libera o acesso em tempo real), mas NINGUÉM escreve pelo
// navegador; só o Worker escreve, com credencial de servidor (service account),
// que passa por fora destas regras. Sem isso, qualquer um se liberaria pelo
// console do navegador.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /subscriptions/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
